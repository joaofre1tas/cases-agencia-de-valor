# Webhook Make — use esta na Vercel (server-side; recomendado). Encaminha /api/submit-application.
MAKE_APPLICATION_WEBHOOK_URL=

# Opcional: só para `npm run dev` se não quiser duplicar (proxy de dev aceita também este valor)
# VITE_MAKE_APPLICATION_WEBHOOK_URL=

# Opcional: iframe do vídeo "próximos passos" na página /confirma (YouTube/Vimeo embed URL)
# VITE_CONFIRMA_VIDEO_EMBED_URL=
# Copie para .env.local e preencha com as credenciais reais do Supabase.
# Projeto Supabase: https://app.supabase.com/project/_/settings/api

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
